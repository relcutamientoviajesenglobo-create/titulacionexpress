---
/**
 * HOME v10 — Next-Gen Landing
 * Scroll-driven animations · OKLCH gradients · Bento layout
 * Cinematic hero · Glassmorphism 2.0 · Fluid typography
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CarreraCard from '../components/CarreraCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const metaTitle = 'Titulación por Experiencia Laboral en México — Acuerdo 286 SEP | Titulación Express';
const metaDesc = 'Obtén tu título de licenciatura mediante el Acuerdo 286 de la SEP. Titúlate por experiencia laboral con validez oficial. 15 carreras disponibles. Evalúa tu perfil gratis.';

const carrerasDestacadas = [
  {
    nombre: 'Lic. en Administración',
    slug: 'administracion',
    tipo: 'no-regulada' as const,
    descripcionCorta: 'Para gerentes, directores y emprendedores con experiencia en gestión empresarial.',
    foto: '/images/photos/business-meeting.jpg',
  },
  {
    nombre: 'Lic. en Derecho',
    slug: 'derecho',
    tipo: 'regulada' as const,
    descripcionCorta: 'Para profesionales con trayectoria en el ámbito jurídico y legal.',
    foto: '/images/photos/lawyer-scales.jpg',
  },
  {
    nombre: 'Lic. en Contaduría',
    slug: 'contaduria',
    tipo: 'regulada' as const,
    descripcionCorta: 'Para contadores y financieros con años de práctica profesional.',
    foto: '/images/photos/accounting-calculator.jpg',
  },
  {
    nombre: 'Lic. en Mercadotecnia',
    slug: 'mercadotecnia',
    tipo: 'no-regulada' as const,
    descripcionCorta: 'Para especialistas en marketing, publicidad y estrategia comercial.',
    foto: '/images/photos/marketing-strategy.jpg',
  },
  {
    nombre: 'Lic. en Pedagogía',
    slug: 'pedagogia',
    tipo: 'no-regulada' as const,
    descripcionCorta: 'Para educadores y formadores con experiencia docente o de capacitación.',
    foto: '/images/photos/teacher-classroom.jpg',
  },
  {
    nombre: 'Lic. en Turismo',
    slug: 'turismo',
    tipo: 'no-regulada' as const,
    descripcionCorta: 'Para operadores turísticos, hoteleros y gestores de experiencias de viaje.',
    foto: '/images/photos/tourism-travel.jpg',
  },
  {
    nombre: 'Lic. en Gastronomía',
    slug: 'gastronomia',
    tipo: 'no-regulada' as const,
    descripcionCorta: 'Para chefs ejecutivos, restauranteros y profesionales culinarios con trayectoria.',
    foto: '/images/photos/chef-kitchen.jpg',
  },
  {
    nombre: 'Ing. Computacional',
    slug: 'ingenieria-computacional',
    tipo: 'regulada' as const,
    descripcionCorta: 'Para desarrolladores, arquitectos de software y líderes técnicos de TI.',
    foto: '/images/photos/computer-coding.jpg',
  },
  {
    nombre: 'Lic. en Diseño Gráfico',
    slug: 'diseno-grafico',
    tipo: 'no-regulada' as const,
    descripcionCorta: 'Para directores creativos, diseñadores senior y profesionales de branding.',
    foto: '/images/photos/design-creative.jpg',
  },
];

const faqItems = [
  {
    question: '¿Es legal la titulación por experiencia laboral en México?',
    answer: 'Sí. El Acuerdo 286 de la Secretaría de Educación Pública establece el marco legal para acreditar conocimientos adquiridos por experiencia laboral o de forma autodidacta. Los títulos son expedidos directamente por la SEP y tienen validez oficial en todo el país. Puedes verificarlo en el sitio oficial de la DGAIR.',
  },
  {
    question: '¿Cuánto tiempo tarda el proceso de titulación?',
    answer: 'El proceso de preparación y evaluaciones toma entre 3 y 6 meses. Después de aprobar los exámenes EGAL y EXOAL, el trámite del título y la cédula profesional puede tomar de 4 a 6 meses adicionales. Los tiempos varían según la carrera y la institución evaluadora.',
  },
  {
    question: '¿Qué carreras puedo acreditar con el Acuerdo 286?',
    answer: 'Actualmente hay 27 licenciaturas disponibles bajo el Acuerdo 286, tanto reguladas como no reguladas. Entre las más solicitadas están Administración, Derecho, Contaduría, Mercadotecnia y Pedagogía. Consulta el listado completo en nuestra sección de carreras disponibles.',
  },
  {
    question: '¿Puedo tramitar mi cédula profesional con el título del Acuerdo 286?',
    answer: 'Sí. El título obtenido mediante el Acuerdo 286 tiene los mismos efectos legales que cualquier título universitario. Puedes tramitar tu cédula profesional federal ante la Dirección General de Profesiones sin ninguna restricción.',
  },
];
---

<BaseLayout
  title={metaTitle}
  description={metaDesc}
  canonical="/"
  schemaType="home"
>

  <!-- ========== HERO v10 — Cinematic with mesh gradient + 3D card ========== -->
  <section class="hero-v10" id="hero-section">
    <div class="hero-v10__canvas" aria-hidden="true">
      <!-- OKLCH mesh gradient blobs -->
      <div class="hero-v10__mesh">
        <div class="hero-v10__blob hero-v10__blob--gold"></div>
        <div class="hero-v10__blob hero-v10__blob--blue"></div>
        <div class="hero-v10__blob hero-v10__blob--teal"></div>
        <div class="hero-v10__blob hero-v10__blob--purple"></div>
      </div>
      <!-- Grain overlay -->
      <div class="hero-v10__grain"></div>
      <!-- Aurora streaks -->
      <div class="hero-v10__aurora">
        <div class="hero-v10__streak hero-v10__streak--1"></div>
        <div class="hero-v10__streak hero-v10__streak--2"></div>
        <div class="hero-v10__streak hero-v10__streak--3"></div>
      </div>
      <!-- Grid pattern -->
      <div class="hero-v10__grid-pattern"></div>
    </div>

    <div class="container hero-v10__inner">
      <div class="hero-v10__content">
        <div class="hero-v10__badge-row">
          <span class="hero-v10__badge">
            <span class="hero-v10__badge-dot"></span>
            Validez oficial SEP · Acuerdo 286
          </span>
        </div>

        <h1 class="hero-v10__title">
          Obtén tu Título de<br/>
          <span class="hero-v10__gradient-text">Licenciatura</span>
          <span class="hero-v10__thin">por Experiencia Laboral</span>
        </h1>

        <p class="hero-v10__desc">
          Titulación Express es un programa de acompañamiento para profesionales mexicanos que desean obtener su título de licenciatura mediante el <a href="/acuerdo-286/">Acuerdo 286 de la SEP</a>, un proceso legal que reconoce los conocimientos adquiridos a través de la experiencia laboral.
        </p>

        <div class="hero-v10__actions">
          <a href="https://wa.me/5215563277530?text=Hola%2C%20quiero%20evaluar%20mi%20perfil%20para%20titulación%20por%20experiencia%20laboral" class="hero-v10__btn-primary" target="_blank" rel="noopener noreferrer">
            <span>Evalúa tu Perfil Gratis</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/titulacion-por-experiencia-laboral/proceso-paso-a-paso/" class="hero-v10__btn-glass">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
            ¿Cómo Funciona?
          </a>
        </div>

        <!-- Bento stats row -->
        <div class="hero-v10__bento-stats">
          <div class="hero-v10__bento-stat hero-v10__bento-stat--accent">
            <span class="hero-v10__bento-number">15</span>
            <span class="hero-v10__bento-label">Carreras<br/>disponibles</span>
          </div>
          <div class="hero-v10__bento-stat">
            <span class="hero-v10__bento-number">3-6</span>
            <span class="hero-v10__bento-label">Meses de<br/>proceso</span>
          </div>
          <div class="hero-v10__bento-stat">
            <span class="hero-v10__bento-number">100%</span>
            <span class="hero-v10__bento-label">Validez<br/>oficial</span>
          </div>
        </div>
      </div>

      <!-- 3D tilted diploma card -->
      <div class="hero-v10__visual">
        <div class="hero-v10__card-glow"></div>
        <div class="hero-v10__floating-card">
          <img src="/images/illustrations/hero-diploma.svg" alt="Título de licenciatura con sello oficial de la SEP obtenido por experiencia laboral mediante el Acuerdo 286" width="480" height="400" loading="eager" />
        </div>
        <!-- Floating micro-badges -->
        <div class="hero-v10__micro-badge hero-v10__micro-badge--1">
          <span>SEP</span>
        </div>
        <div class="hero-v10__micro-badge hero-v10__micro-badge--2">
          <span>CENEVAL</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRUST SIGNALS — Glassmorphism 2.0 ========== -->
  <section class="home-trust scroll-reveal">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-card">
          <div class="trust-card__icon">
            <img src="/images/trust/sep-shield.svg" alt="SEP" width="48" height="48" />
          </div>
          <div>
            <h3 class="trust-card__title">Validez Oficial SEP</h3>
            <p class="trust-card__desc">Título con los mismos efectos legales que cualquier universidad</p>
          </div>
        </div>
        <div class="trust-card">
          <div class="trust-card__icon">
            <img src="/images/trust/ceneval-badge.svg" alt="CENEVAL" width="48" height="48" />
          </div>
          <div>
            <h3 class="trust-card__title">Evaluación CENEVAL</h3>
            <p class="trust-card__desc">Exámenes diseñados por la máxima autoridad evaluadora de México</p>
          </div>
        </div>
        <div class="trust-card">
          <div class="trust-card__icon">
            <img src="/images/trust/cedula-card.svg" alt="Cédula" width="48" height="48" />
          </div>
          <div>
            <h3 class="trust-card__title">Cédula Profesional</h3>
            <p class="trust-card__desc">Trámite de cédula federal incluido en el acompañamiento</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== QUÉ ES — Editorial layout with scroll reveal ========== -->
  <section class="home-about scroll-reveal" id="que-es">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <span class="section-label">¿Qué es?</span>
          <h2>Titulación por Experiencia Laboral</h2>
          <p>
            La titulación por experiencia laboral es un proceso regulado por el <a href="/acuerdo-286/que-es/">Acuerdo 286</a> de la Secretaría de Educación Pública de México que permite a profesionales con mínimo 3 a 5 años de experiencia obtener un título de licenciatura con validez oficial en todo el país.
          </p>
          <p>
            El proceso consta de dos evaluaciones principales: el <a href="/acuerdo-286/examen-egal-ceneval/">examen escrito EGAL</a> y la <a href="/acuerdo-286/examen-oral-exoal/">evaluación oral EXOAL</a>. Los títulos tienen los mismos efectos legales que cualquier título universitario y permiten <a href="/cedula-profesional/">tramitar la cédula profesional</a> federal.
          </p>
          <p>
            Este proceso es ideal para gerentes, directores, emprendedores, docentes, contadores, abogados y profesionales que han construido su carrera con años de trabajo pero nunca obtuvieron un título universitario. Conoce los <a href="/titulacion-por-experiencia-laboral/requisitos/">requisitos completos</a>.
          </p>
        </div>
        <div class="about-visual">
          <div class="about-photo-stack">
            <img src="/images/photos/woman-professional.jpg" alt="Profesional mexicana" class="about-photo about-photo--main" width="400" height="500" loading="lazy" />
            <img src="/images/photos/signing-document.jpg" alt="Firma de documentos" class="about-photo about-photo--accent" width="250" height="200" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROCESO — Bento-style steps ========== -->
  <section class="home-proceso scroll-reveal" id="proceso">
    <div class="container">
      <div class="section-header-center">
        <span class="section-label">¿Cómo funciona?</span>
        <h2>Tu título en 4 pasos</h2>
        <p>El proceso de <a href="/titulacion-por-experiencia-laboral/">titulación por experiencia laboral</a> es claro, estructurado y con acompañamiento en cada etapa.</p>
      </div>
      <div class="steps-grid scroll-reveal-stagger">
        <div class="step-card">
          <div class="step-card__number">01</div>
          <div class="step-card__icon">
            <img src="/images/proceso/paso-1-evaluacion.svg" alt="Evaluación de perfil" width="64" height="64" />
          </div>
          <h3 class="step-card__title">Evaluación de Perfil</h3>
          <p class="step-card__desc">Analizamos tu experiencia laboral para determinar la carrera ideal y tu viabilidad de aprobación.</p>
          <span class="step-card__time">1-2 días</span>
        </div>
        <div class="step-card">
          <div class="step-card__number">02</div>
          <div class="step-card__icon">
            <img src="/images/proceso/paso-2-preparacion.svg" alt="Preparación" width="64" height="64" />
          </div>
          <h3 class="step-card__title">Preparación Personalizada</h3>
          <p class="step-card__desc">Material de estudio y simulacros diseñados para tu carrera y perfil específico.</p>
          <span class="step-card__time">2-4 meses</span>
        </div>
        <div class="step-card">
          <div class="step-card__number">03</div>
          <div class="step-card__icon">
            <img src="/images/proceso/paso-3-evaluaciones.svg" alt="Evaluaciones" width="64" height="64" />
          </div>
          <h3 class="step-card__title">Evaluaciones EGAL + EXOAL</h3>
          <p class="step-card__desc">Presentas el examen escrito del CENEVAL y la evaluación oral ante la institución autorizada.</p>
          <span class="step-card__time">1-2 semanas</span>
        </div>
        <div class="step-card">
          <div class="step-card__number">04</div>
          <div class="step-card__icon">
            <img src="/images/proceso/paso-4-titulo.svg" alt="Título y Cédula" width="64" height="64" />
          </div>
          <h3 class="step-card__title">Título + Cédula Profesional</h3>
          <p class="step-card__desc">Recibes tu título oficial de la SEP y tramitamos tu cédula profesional federal.</p>
          <span class="step-card__time">1-2 meses</span>
        </div>
      </div>
      <div class="section-cta-center">
        <a href="/titulacion-por-experiencia-laboral/proceso-paso-a-paso/" class="btn btn--outline">Ver el proceso completo →</a>
      </div>
    </div>
  </section>

  <!-- ========== CARRERAS DESTACADAS ========== -->
  <section class="home-carreras scroll-reveal" id="carreras">
    <div class="container">
      <div class="section-header-center">
        <span class="section-label">15 licenciaturas</span>
        <h2>Carreras Disponibles</h2>
        <p>
          Divididas entre <a href="/acuerdo-286/carreras-reguladas-vs-no-reguladas/">carreras reguladas y no reguladas</a>. Las no reguladas no requieren créditos universitarios previos. Consulta el <a href="/acuerdo-286/carreras-disponibles/">catálogo completo</a>.
        </p>
      </div>
      <div class="carreras-home-grid">
        {carrerasDestacadas.map(c => (
          <CarreraCard
            nombre={c.nombre}
            slug={c.slug}
            tipo={c.tipo}
            descripcionCorta={c.descripcionCorta}
            foto={c.foto}
          />
        ))}
      </div>
      <div class="section-cta-center">
        <a href="/carreras/" class="btn btn--primary">Ver las 15 Carreras Disponibles</a>
      </div>
    </div>
  </section>

  <!-- ========== ACUERDO 286 — Dark premium ========== -->
  <section class="home-acuerdo scroll-reveal" id="acuerdo-286">
    <div class="home-acuerdo__bg" aria-hidden="true">
      <div class="home-acuerdo__orb home-acuerdo__orb--1"></div>
      <div class="home-acuerdo__orb home-acuerdo__orb--2"></div>
    </div>
    <div class="container">
      <div class="acuerdo-grid">
        <div class="acuerdo-content">
          <span class="section-label section-label--light">Marco legal</span>
          <h2>Respaldado por el Acuerdo 286 de la SEP</h2>
          <p>
            Disposición oficial publicada en el Diario Oficial de la Federación en el año 2000 que establece los procedimientos para acreditar conocimientos adquiridos por experiencia laboral. Las evaluaciones son aplicadas por <a href="/acuerdo-286/instituciones-evaluadoras/">instituciones autorizadas</a> por la DGAIR de la SEP.
          </p>
          <div class="acuerdo-features">
            <div class="acuerdo-feat">
              <span class="acuerdo-feat__icon">📋</span>
              <span>Publicado en el DOF</span>
            </div>
            <div class="acuerdo-feat">
              <span class="acuerdo-feat__icon">🏛️</span>
              <span>Avalado por la SEP</span>
            </div>
            <div class="acuerdo-feat">
              <span class="acuerdo-feat__icon">🎯</span>
              <span>Exámenes CENEVAL</span>
            </div>
            <div class="acuerdo-feat">
              <span class="acuerdo-feat__icon">✅</span>
              <span>Cédula profesional</span>
            </div>
          </div>
          <a href="/acuerdo-286/" class="home-acuerdo__btn">Guía Completa del Acuerdo 286 →</a>
        </div>
        <div class="acuerdo-visual">
          <img src="/images/illustrations/acuerdo-286-document.svg" alt="Documento Acuerdo 286" width="380" height="320" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PARALLAX — Graduation ========== -->
  <section class="home-parallax scroll-fade">
    <div class="home-parallax__bg" style="background-image: url(/images/photos/cap-and-diploma.jpg)"></div>
    <div class="home-parallax__overlay"></div>
    <div class="container home-parallax__content">
      <h2>Tu Título de Licenciatura Te Espera</h2>
      <p>Únete a los profesionales mexicanos que ya validaron su experiencia y obtuvieron su título con validez oficial de la SEP.</p>
      <a href="https://wa.me/5215563277530?text=Hola%2C%20quiero%20evaluar%20mi%20perfil%20para%20titulación%20por%20experiencia%20laboral" class="hero-v10__btn-primary" style="display: inline-flex;" target="_blank" rel="noopener noreferrer">
        <span>Evalúa tu Perfil Gratis</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ========== COSTOS ========== -->
  <section class="home-costos scroll-reveal" id="inversion">
    <div class="container">
      <div class="costos-card">
        <div class="costos-card__content">
          <span class="section-label">Inversión</span>
          <h2>Costos Transparentes</h2>
          <p>
            El costo incluye preparación personalizada, derechos de evaluación CENEVAL y trámites de título y cédula profesional. Los costos varían entre carreras reguladas y no reguladas.
          </p>
          <a href="/titulacion-por-experiencia-laboral/costo/" class="btn btn--primary">Ver desglose completo de costos →</a>
        </div>
        <div class="costos-card__visual">
          <img src="/images/photos/costos-inversion.jpg" alt="Inversión transparente en titulación por experiencia laboral" width="480" height="320" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIOS ========== -->
  <section class="home-testimonios scroll-reveal" id="testimonios">
    <div class="container">
      <div class="section-header-center">
        <span class="section-label">Experiencias reales</span>
        <h2>Profesionales que Ya Obtuvieron su Título</h2>
        <p>Cada historia es un ejemplo real de cómo la <a href="/titulacion-por-experiencia-laboral/testimonios/">titulación por experiencia laboral</a> transforma carreras en México.</p>
      </div>
      <div class="testimonios-grid scroll-reveal-stagger">
        <div class="testi-card">
          <div class="testi-card__stars">★★★★★</div>
          <blockquote class="testi-card__quote">"Tenía 15 años dirigiendo empresas sin título. El proceso fue riguroso pero el acompañamiento hizo toda la diferencia. Hoy tengo mi cédula profesional."</blockquote>
          <div class="testi-card__author">
            <div class="testi-card__avatar">RG</div>
            <div>
              <strong class="testi-card__name">Roberto García M.</strong>
              <span class="testi-card__role">Director de Operaciones · Administración · 2025</span>
            </div>
          </div>
        </div>
        <div class="testi-card">
          <div class="testi-card__stars">★★★★★</div>
          <blockquote class="testi-card__quote">"Trabajé 12 años como contadora sin título. Con el Acuerdo 286 pude acreditar todo lo que ya sabía. El examen EGAL fue exigente, pero estaba preparada."</blockquote>
          <div class="testi-card__author">
            <div class="testi-card__avatar">MR</div>
            <div>
              <strong class="testi-card__name">María Elena Ríos</strong>
              <span class="testi-card__role">Contadora independiente · Contaduría · 2025</span>
            </div>
          </div>
        </div>
        <div class="testi-card">
          <div class="testi-card__stars">★★★★★</div>
          <blockquote class="testi-card__quote">"A los 42 años obtuve mi título de licenciatura. Nunca pensé que era posible sin regresar a la universidad. El equipo de Titulación Express me guió en todo."</blockquote>
          <div class="testi-card__author">
            <div class="testi-card__avatar">LH</div>
            <div>
              <strong class="testi-card__name">Luis Hernández P.</strong>
              <span class="testi-card__role">Director Comercial · Mercadotecnia · 2024</span>
            </div>
          </div>
        </div>
      </div>
      <div class="section-cta-center">
        <a href="/titulacion-por-experiencia-laboral/testimonios/" class="btn btn--outline">Ver más testimonios →</a>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="home-faq scroll-reveal" id="preguntas-frecuentes">
    <div class="container">
      <div class="faq-layout">
        <div class="faq-header">
          <span class="section-label">Resuelve tus dudas</span>
          <h2>Preguntas Frecuentes</h2>
          <p>Las respuestas más comunes sobre la titulación por experiencia laboral.</p>
          <a href="/titulacion-por-experiencia-laboral/preguntas-frecuentes/" class="btn btn--outline" style="margin-top: var(--space-md);">Ver todas las preguntas →</a>
        </div>
        <div class="faq-content">
          <FAQAccordion items={faqItems} />
        </div>
      </div>
