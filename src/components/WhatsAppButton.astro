---
/**
 * WhatsAppButton.astro — Botón flotante de WhatsApp
 * CSS-only, sin JS. Link directo a wa.me
 * Micro-interacciones: pulse ring + tooltip hover + entrada animada
 */
interface Props {
  phone?: string;
  message?: string;
}

const { phone = '5563277530', message = 'Hola, me interesa información sobre la titulación por experiencia laboral.' } = Astro.props;

const waUrl = `https://wa.me/52${phone}?text=${encodeURIComponent(message)}`;
---

<a
  href={waUrl}
  class="whatsapp-btn"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
>
  <svg class="whatsapp-btn__icon" viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<style>
  /* ─── Entry animation: bounce in from bottom ─── */
  @keyframes wa-bounce-in {
    0%   { opacity: 0; transform: translateY(80px) scale(0.5); }
    60%  { opacity: 1; transform: translateY(-8px) scale(1.05); }
    80%  { transform: translateY(3px) scale(0.98); }
    100% { transform: translateY(0) scale(1); }
  }

  /* ─── Pulse ring ─── */
  @keyframes wa-pulse {
    0%   { transform: scale(1); opacity: 0.5; }
    70%  { transform: scale(2); opacity: 0; }
    100% { transform: scale(2); opacity: 0; }
  }

  .whatsapp-btn {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 56px;
    height: 56px;
    background: #25D366;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.45);
    z-index: 900;
    text-decoration: none;
    overflow: visible;
    /* Entry animation */
    animation: wa-bounce-in 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 1.2s both;
    /* Hover transitions */
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
  }

  /* ─── Pulse ring via ::before ─── */
  .whatsapp-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 50%;
    background: #25D366;
    z-index: -1;
    animation: wa-pulse 3s ease-out 2.5s infinite;
  }

  /* ─── Tooltip via ::after (desktop only, pure CSS) ─── */
  .whatsapp-btn::after {
    content: '¿Dudas? Escríbenos';
    position: absolute;
    right: calc(100% + 14px);
    top: 50%;
    transform: translateY(-50%) translateX(8px);
    background: #1a1a2e;
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: 'Plus Jakarta Sans', 'Inter', system-ui, sans-serif;
    white-space: nowrap;
    padding: 0.5rem 0.875rem;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  /* ─── Hover: scale + glow + show tooltip ─── */
  .whatsapp-btn:hover {
    transform: scale(1.12);
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.55);
  }

  .whatsapp-btn:hover::before {
    animation-play-state: paused;
    opacity: 0;
  }

  .whatsapp-btn:hover::after {
    opacity: 1;
    visibility: visible;
    transform: translateY(-50%) translateX(0);
  }

  /* ─── Active press ─── */
  .whatsapp-btn:active {
    transform: scale(0.95);
    box-shadow: 0 2px 8px rgba(37, 211, 102, 0.4);
  }

  /* ─── Icon tilt on hover ─── */
  .whatsapp-btn__icon {
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .whatsapp-btn:hover .whatsapp-btn__icon {
    transform: rotate(-8deg) scale(1.05);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .whatsapp-btn {
      bottom: 1rem;
      right: 1rem;
      width: 52px;
      height: 52px;
    }

    /* No tooltip on mobile (no hover on touch) */
    .whatsapp-btn::after {
      display: none;
    }
  }

  /* ─── Respect reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .whatsapp-btn {
      animation: none;
    }
    .whatsapp-btn::before {
      animation: none;
    }
  }
</style>
