---
/**
 * CarreraCard.astro — Airbnb-style career card with photo
 */
interface Props {
  nombre: string;
  slug: string;
  tipo: 'regulada' | 'no-regulada';
  descripcionCorta: string;
  foto?: string;
}

const { nombre, slug, tipo, descripcionCorta, foto } = Astro.props;
---

<a href={`/carreras/${slug}/`} class="cc">
  <div class="cc__media">
    {foto ? (
      <img src={foto} alt={nombre} width="400" height="260" loading="lazy" class="cc__img" />
    ) : (
      <div class="cc__placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1 2 3 6 3s6-2 6-3v-5"/></svg>
      </div>
    )}
    <div class="cc__badge-wrap">
      <span class={`cc__badge ${tipo === 'regulada' ? 'cc__badge--reg' : 'cc__badge--noreg'}`}>
        {tipo === 'regulada' ? '🎓 Regulada' : '✨ Sin créditos previos'}
      </span>
    </div>
  </div>
  <div class="cc__body">
    <h3 class="cc__name">{nombre}</h3>
    <p class="cc__desc">{descripcionCorta}</p>
    <span class="cc__link">
      Conocer requisitos
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </span>
  </div>
</a>

<style>
  .cc {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface-0);
    border: 1px solid var(--border-subtle);
    transition: border-color var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out),
                transform var(--duration-base) var(--ease-out);
    position: relative;
  }

  .cc:hover {
    border-color: var(--border-default);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  /* Media / Image */
  .cc__media {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--surface-2);
  }

  .cc__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-cinematic);
  }

  .cc:hover .cc__img {
    transform: scale(1.04);
  }

  .cc__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }

  /* Badge over image */
  .cc__badge-wrap {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    z-index: 2;
  }

  .cc__badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 5px 12px;
    border-radius: var(--radius-full, 999px);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
  }

  .cc__badge--reg {
    background: oklch(35% 0.12 250 / 0.88);
    color: oklch(95% 0 0);
  }

  .cc__badge--noreg {
    background: oklch(99% 0 0 / 0.9);
    color: var(--brand-dark);
    border: 1px solid oklch(90% 0 0 / 0.5);
  }

  /* Body */
  .cc__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .cc__name {
    font-size: var(--step-0);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .cc__desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cc__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: var(--space-xs);
    transition: gap var(--duration-base) var(--ease-out), color var(--duration-fast) var(--ease-out);
  }

  .cc:hover .cc__link {
    gap: 10px;
    color: var(--accent-dark);
  }

  .cc__link svg {
    transition: transform var(--duration-base) var(--ease-out);
  }

  .cc:hover .cc__link svg {
    transform: translateX(3px);
  }
</style>
