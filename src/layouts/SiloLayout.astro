---
/**
 * SiloLayout.astro — Layout para páginas de SILO (hubs y subpáginas)
 * Incluye breadcrumbs, sidebar de navegación del silo, CTA
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  breadcrumbs: Array<{ name: string; url: string }>;
  schemaType?: 'silo' | 'faq' | 'page';
  faq?: Array<{ question: string; answer: string }>;
  siloNav?: Array<{ name: string; url: string; active?: boolean }>;
  headerImage?: string;
}

const {
  title,
  description,
  canonical,
  breadcrumbs,
  schemaType = 'silo',
  faq,
  siloNav = [],
  headerImage,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  schemaType={schemaType}
  breadcrumbs={breadcrumbs}
  faq={faq}
>
  <div class="silo-page">
    {headerImage && (
      <div class="silo-photo-header" style={`background-image: url(${headerImage})`}>
        <div class="container">
          <Breadcrumbs items={breadcrumbs} />
        </div>
      </div>
    )}
    {!headerImage && (
      <div class="container">
        <Breadcrumbs items={breadcrumbs} />
      </div>
    )}

    <div class="silo-page__layout container">
      <!-- Main Content -->
      <article class="silo-page__content">
        <slot />
      </article>

      <!-- Sidebar: SILO Navigation -->
      {siloNav.length > 0 && (
        <aside class="silo-page__sidebar" aria-label="Navegación del tema">
          <nav class="silo-nav">
            <h3 class="silo-nav__title">En esta sección</h3>
            <ul class="silo-nav__list">
              {siloNav.map(item => (
                <li>
                  <a
                    href={item.url}
                    class={`silo-nav__link ${item.active ? 'silo-nav__link--active' : ''}`}
                    aria-current={item.active ? 'page' : undefined}
                  >
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </nav>

          <!-- CTA Sidebar -->
          <div class="silo-sidebar-cta">
            <p class="silo-sidebar-cta__text">¿Tienes experiencia laboral? Evalúa si puedes titularte.</p>
            <a href="https://wa.me/5215563277530?text=Hola%2C%20quiero%20evaluar%20mi%20perfil%20para%20titulación%20por%20experiencia%20laboral" class="btn btn--primary" style="width:100%;text-align:center;" target="_blank" rel="noopener noreferrer">
              Evalúa tu Perfil Gratis
            </a>
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .silo-page {
    padding-bottom: var(--space-3xl);
  }

  .silo-page__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  .silo-page__content {
    max-width: 100%;
    min-width: 0;
  }

  .silo-page__content :global(h1) {
    margin-bottom: var(--space-lg);
  }

  .silo-page__content :global(h2) {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .silo-page__content :global(h3) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .silo-page__content :global(p) {
    margin-bottom: var(--space-md);
    max-width: 70ch;
  }

  .silo-page__content :global(ul),
  .silo-page__content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-xl);
  }

  .silo-page__content :global(li) {
    margin-bottom: var(--space-sm);
    line-height: 1.7;
  }

  /* Sidebar */
  .silo-page__sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .silo-nav {
    background: var(--surface-1);
    border-radius: var(--radius-lg);
    padding: var(--space-md) var(--space-lg);
    border: 1px solid var(--border-subtle);
  }

  .silo-nav__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .silo-nav__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .silo-nav__link {
    display: block;
    padding: 0.375rem var(--space-sm);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8125rem;
    line-height: 1.4;
    border-radius: var(--radius-sm);
    transition: all var(--duration-fast) var(--ease-out);
    border-left: 3px solid transparent;
  }

  .silo-nav__link:hover {
    background: var(--surface-0);
    color: var(--brand);
  }

  .silo-nav__link--active {
    background: var(--surface-0);
    color: var(--brand);
    font-weight: 600;
    border-left-color: var(--accent);
  }

  .silo-sidebar-cta {
    background: var(--surface-dark);
    color: var(--text-on-dark);
    border-radius: var(--radius-lg);
    padding: var(--space-md) var(--space-lg);
  }

  .silo-sidebar-cta__text {
    font-size: 0.8125rem;
    margin-bottom: var(--space-sm);
    color: var(--text-on-dark-muted);
    line-height: 1.4;
  }

  @media (min-width: 1024px) {
    .silo-page__layout {
      grid-template-columns: 1fr 300px;
    }

    .silo-page__sidebar {
      position: sticky;
      top: calc(var(--header-height) + var(--space-lg));
      align-self: start;
    }
  }
</style>
